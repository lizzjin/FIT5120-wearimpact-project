      "id": "WRAP_2017",
      "title": "Valuing Our Clothes: the cost of UK fashion",
      "publisher": "WRAP (Waste & Resources Action Programme)",
      "year": 2017,
      "scope": "UK aggregate, cradle-to-grave"
