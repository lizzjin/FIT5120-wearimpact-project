  "interventions": {
    "extend_lifetime_2x": {
      "label": "Wear each item twice as long before disposal",
      "co2_reduction_pct": 44,
      "water_reduction_pct": 44,
      "waste_reduction_pct": 44,
      "applies_to": "all_garments",
      "source": "WRAP_2017 Table 10 (extending active life of clothes by 9 months)"
    },
    "extend_lifetime_9_months": {
      "label": "Extend active life by 9 months",
      "co2_reduction_pct": 8,
      "water_reduction_pct": 10,
      "waste_reduction_pct": 9,
      "applies_to": "all_garments",
      "source": "WRAP_2017 Table 10"
    },
    "wash_cold_30c": {
      "label": "Wash at 30 degC instead of 40 degC",
      "co2_reduction_pct": 5,
      "applies_to": "use_phase",
      "source": "IMPRO_2014 Section 4.5"
    },
    "full_load_washing": {
      "label": "Wait for a full load before washing",
      "co2_reduction_pct": 10,
      "water_reduction_pct": 12,
      "applies_to": "use_phase",
      "source": "IMPRO_2014 Section 4.5"
    },
    "line_dry_no_tumble": {
      "label": "Air-dry clothes instead of tumble drying",
      "co2_reduction_pct": 13,
      "applies_to": "use_phase",
      "source": "IMPRO_2014 Section 4.5"
    },
    "buy_second_hand": {
      "label": "Buy a second-hand garment instead of new",
      "co2_avoided_pct": 80,
      "water_avoided_pct": 80,
      "applies_to": "purchase_decision",
      "source": "WRAP_2017 Figure 18 (re-use displaces new production)"
    },
    "donate_dont_landfill": {
      "label": "Donate / resell instead of binning",
      "co2_avoided_per_kg": 3.2,
      "applies_to": "disposal",
      "source": "WRAP_2017 Figure 15 (UK disposal route mix)"
    },
    "switch_to_recycled_fibre": {
      "label": "Buy garments made from 40% recycled fibre",
      "co2_reduction_pct": 5.9,
      "water_reduction_pct": 4.4,
      "applies_to": "purchase_decision",
      "source": "QUANTIS_2018 Action Item 3 (40% recycled fibre target)"
    },
    "renewable_energy_supply_chain": {
      "label": "Choose brands committed to 60% renewable energy",
      "co2_reduction_pct": 39,
      "water_reduction_pct": 16.9,
      "applies_to": "purchase_decision",
      "source": "QUANTIS_2018 Action Item 1"
    }
  },

