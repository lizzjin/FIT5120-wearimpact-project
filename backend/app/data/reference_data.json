    {
      "id": "IMPRO_2014",
      "title": "Environmental Improvement Potential of Textiles (IMPRO Textiles)",
      "publisher": "European Commission Joint Research Centre (JRC)",
      "year": 2014,
      "scope": "EU-27, per-fibre and per-garment LCA"
    },
    {
      "id": "QUANTIS_2018",
      "title": "Measuring Fashion: Environmental Impact of the Global Apparel and Footwear Industries Study",
      "publisher": "Quantis",
      "year": 2018,
      "scope": "Global, IMPACT 2002+ method, includes footwear"
    }
  ],
  "disclaimers": {
    "geography": "Australia-specific benchmarks were not available at time of publication. Figures are derived from UK (WRAP), EU (IMPRO), and global (Quantis) datasets and used as best available proxies.",
    "use_phase": "Quantis 2018 excludes the consumer use phase (washing, drying). Use-phase intensities are sourced from IMPRO 2014.",
    "fibre_assumption": "All fibres are modelled as conventional (non-organic, non-recycled) unless explicitly stated."
  },

