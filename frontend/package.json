{
  "name": "wearimpact-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .js,.vue",
    "lint:fix": "eslint . --ext .js,.vue --fix",
    "format": "prettier --write \"src/**/*.{js,vue,css,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,vue,css,scss,json}\"",
    "hooks:enable": "git -C .. config --local core.hooksPath frontend/.husky"
  },
  "lint-staged": {
    "*.{js,vue}": [
      "eslint --fix"
    ],
    "*.{js,vue,css,scss,json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@gradio/client": "^1.5.0",
    "@iconify/vue": "^5.0.0",
    "browser-image-compression": "^2.0.2",
    "dexie": "^4.4.2",
    "driver.js": "^1.4.0",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "lucide-vue-next": "^0.511.0",
    "mapbox-gl": "^3.21.0",
    "radix-vue": "^1.9.17",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "vue3-lottie": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "eslint": "^9.17.0",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.2.2",
    "vite": "^5.4.11"
  }
}
